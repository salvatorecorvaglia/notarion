# =========================================
# EVM IPFS UPLOAD - CENTRALIZED ENVIRONMENT
# =========================================
# Single .env file for the entire project

# =========================================
# MONGODB CONFIGURATION
# =========================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin

# MongoDB URI for local development (no auth)
# MONGO_URI=mongodb://localhost:27017/ipfs-upload

# MongoDB URI for Docker or with authentication
MONGO_URI=mongodb://admin:admin@localhost:27017/ipfs-upload?authSource=admin

# =========================================
# BACKEND SERVER CONFIGURATION
# =========================================
PORT=5002
NODE_ENV=development
TZ=Europe/Rome

# =========================================
# FRONTEND VITE CONFIGURATION
# =========================================
VITE_SERVER_URL=http://localhost:5002
VITE_IPFS_GATEWAY_URL=http://localhost:8080

# =========================================
# LOCAL IPFS CONFIGURATION
# =========================================
# IPFS API url. If running via docker-compose on the same machine:
IPFS_API_URL=http://localhost:5001
# The public gateway to access IPFS files
IPFS_GATEWAY_URL=https://ipfs.io

# Upload Settings
IPFS_TIMEOUT=60000
IPFS_MAX_RETRIES=2
MAX_FILE_SIZE=104857600

# =========================================
# BACKEND SECURITY CONFIGURATION
# =========================================
# CORS - Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# IPFS-specific Rate Limiting
IPFS_RATE_LIMIT_WINDOW_MS=900000
IPFS_RATE_LIMIT_MAX_REQUESTS=10

# =========================================
# ETHEREUM NETWORK CONFIGURATION
# =========================================
# Network for explorer URLs (mainnet, goerli, sepolia, etc.)
ETH_NETWORK=sepolia