{
    "name": "notarion-server",
    "version": "0.1.0",
    "main": "server.ts",
    "scripts": {
        "start": "nodemon --exec ts-node --transpile-only server.ts",
        "start:prod": "tsc && NODE_ENV=production node dist/server.js",
        "build": "tsc",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest --runInBand",
        "test:coverage": "jest --runInBand --coverage"
    },
    "dependencies": {
        "axios": "^1.15.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "ethers": "^6.13.3",
        "express": "^4.21.1",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.2.0",
        "file-type": "^22.0.1",
        "form-data": "^4.0.5",
        "helmet": "^8.1.0",
        "mongoose": "^8.7.1",
        "multer": "^2.0.2",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.3.0",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.58.1",
        "@typescript-eslint/parser": "^8.58.1",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "jest": "^30.2.0",
        "mongodb-memory-server": "^11.0.1",
        "nodemon": "^3.1.7",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
